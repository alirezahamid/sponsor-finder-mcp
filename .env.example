# SponsorFinder MCP server configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# Base URL of the upstream SponsorFinder API (no trailing slash).
SPONSORFINDER_API_BASE=https://api.sponsorfinder.io

# Upstream API key sent as the `x-api-key` header on every request.
# This is a SERVER-SIDE SECRET. MCP clients connect authless; they never see it.
SPONSORFINDER_API_KEY=sk_sponsor_finder_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HTTP port for the Node entry (src/entry/node.ts). Ignored by stdio / Workers.
PORT=3001

# Upstream request timeout in milliseconds. Optional, default 10000.
UPSTREAM_TIMEOUT_MS=10000

# SponsorFinder MCP server configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# Base URL of the upstream SponsorFinder API (no trailing slash).
SPONSORFINDER_API_BASE=https://api.sponsorfinder.io

# Upstream API key sent as the `x-api-key` header on every request.
# This is a SERVER-SIDE SECRET. MCP clients connect authless; they never see it.
SPONSORFINDER_API_KEY=sk_sponsor_finder_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HTTP port for the Node entry (src/entry/node.ts). Ignored by stdio / Workers.
PORT=3001

# Upstream request timeout in milliseconds. Optional, default 10000.
UPSTREAM_TIMEOUT_MS=10000

# --- Analytics (optional) -----------------------------------------------------
# Server-side GA4 via the Measurement Protocol. Analytics are OFF unless BOTH of
# the following are set. Events are categorical only (tool, verdict, country,
# client, latency bucket, error kind) — never company names or free-text queries.
# Create these in GA4: Admin -> Data Streams -> your stream -> Measurement
# Protocol API secrets.
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=xxxxxxxxxxxxxxxxxxxxxx
# Send to GA's validation endpoint instead of live (for testing). Default false.
GA_DEBUG=false

# Opt-in: also record searched company names to the server's OWN structured logs
# (never sent to GA) for unmet-demand analysis. Default false (queries stay private).
CAPTURE_QUERY_NAMES=false
